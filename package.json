{
	"name": "@iqai/mcp-opinion",
	"version": "0.1.1",
	"description": "MCP server for interacting with Opinion.trade prediction markets on BNB Chain",
	"main": "dist/index.js",
	"type": "module",
	"bin": {
		"mcp-opinion": "dist/index.js"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc && shx chmod +x dist/index.js",
		"prepare": "husky",
		"watch": "tsc --watch",
		"start": "node dist/index.js",
		"publish-packages": "pnpm run build && changeset publish",
		"format": "biome format . --write",
		"lint": "biome check ."
	},
	"publishConfig": {
		"access": "public"
	},
	"keywords": [
		"mcp",
		"opinion",
		"prediction-markets",
		"bnb-chain",
		"trading",
		"fastmcp"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/IQAIcom/mcp-opinion"
	},
	"dependencies": {
		"dedent": "^1.6.0",
		"fastmcp": "^3.30.1",
		"zod": "^3.25.7"
	},
	"devDependencies": {
		"@biomejs/biome": "*",
		"@changesets/cli": "^2.29.4",
		"@types/node": "^22.15.19",
		"husky": "^9.0.0",
		"lint-staged": "^15.0.0",
		"shx": "^0.3.4",
		"typescript": "^5.8.3",
		"zod-to-json-schema": "^3.25.1"
	},
	"lint-staged": {
		"*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
			"biome check --write --organize-imports-enabled=false --no-errors-on-unmatched"
		]
	}
}
